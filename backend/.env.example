# ═══════════════════════════════════════════════════════════════
# TRaMS Portfolio — Cloud Environment Variables (.env.example)
# Copy this to .env and fill in real values
# ═══════════════════════════════════════════════════════════════

# ── Zerodha ──────────────────────────────────────────────────────
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=
# Expires daily at 6am IST → run: python3 zerodha_auth.py

# ── Sharekhan ────────────────────────────────────────────────────
SHAREKHAN_API_KEY=
SHAREKHAN_SECRET_KEY=
SHAREKHAN_USER_ID=
SHAREKHAN_CUSTOMER_ID=
SHAREKHAN_API_NAME=
SHAREKHAN_REDIRECT_URI=http://localhost/
SHAREKHAN_REQUEST_TOKEN=
SHAREKHAN_ACCESS_TOKEN=
# Expires daily → run: sudo python3 sharekhan_auth.py

# ── Interactive Brokers (TWS — local Mac only) ────────────────────
TWS_HOST=127.0.0.1
TWS_PORT=7496
TWS_CLIENT_ID=20
IBKR_ACCOUNT_ID=
IBKR_ACCOUNTS=
# TWS must be running locally. Not used in cloud deployment.

# ── eToro — Selvam ────────────────────────────────────────────────
ETORO_PUBLIC_KEY=
ETORO_USER_KEY=

# ── eToro — Radhika ───────────────────────────────────────────────
ETORO_RADHIKA_PUBLIC_KEY=
ETORO_RADHIKA_USER_KEY=

# ── Aionion Capital — Radhika ─────────────────────────────────────
AIONION_TOKEN=
AIONION_USER_ID=R000400
# Expires periodically → run: python3 aionion_auth.py

# ── PostgreSQL ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── Render.com (for auto-push of refreshed tokens) ───────────────
RENDER_API_KEY=
RENDER_SERVICE_ID=
